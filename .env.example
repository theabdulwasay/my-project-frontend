# Copy to .env and edit before: docker compose up --build
#   copy .env.example .env

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Docker MySQL (must match docker-compose db service)
DB_NAME=wah_tour_db
DB_USER=wah_user
DB_PASSWORD=wah_pass_change_me
MYSQL_ROOT_PASSWORD=root_pass_change_me
DB_HOST=db
DB_PORT=3306

# Admin account (created/updated on seed)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-strong-admin-password

# Email (Gmail app password) — leave blank to show OTP on screen in DEBUG mode
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# Production (when deploying)
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

WEB_PORT=8000
SEED_ON_START=true
GUNICORN_WORKERS=3
